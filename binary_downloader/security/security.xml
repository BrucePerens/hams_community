<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_binary_downloader_manager" model="res.groups">
            <field name="name">Binary Downloader Manager</field>
        </record>
    </data>
    <data>
        <record id="user_binary_downloader_service" model="res.users">
            <field name="name">Binary Downloader Service</field>
            <field name="login">binary_downloader_service</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="company_ids" eval="[(4, ref('base.main_company'))]"/>
            <field name="notification_type">email</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('binary_downloader.group_binary_downloader_manager')])]"/>
        </record>
    </data>
</odoo>
