<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_compliance_service" model="res.groups">
            <field name="name">Micro-Privilege: Compliance Service</field>
        </record>

        <record id="user_compliance_service" model="res.users">
            <field name="name">Compliance Service Account</field>
            <field name="login">user_compliance_service</field>
            <field name="is_service_account" eval="True"/>
            <field name="active" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('compliance.group_compliance_service')])]"/>
        </record>
    </data>
</odoo>
