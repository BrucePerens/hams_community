<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_zero_sudo_binary_manifest_list" model="ir.ui.view"> <field name="name">zero_sudo.binary.manifest.list</field>
        <field name="model">zero_sudo.binary.manifest</field>
        <field name="arch" type="xml">
            <list string="Binary Manifests">
                <field name="name"/>
                <field name="archive_type"/>
                <field name="url"/>
                <field name="checksum"/>
            </list>
        </field>
    </record>

    <record id="view_zero_sudo_binary_manifest_form" model="ir.ui.view"> <field name="name">zero_sudo.binary.manifest.form</field>
        <field name="model">zero_sudo.binary.manifest</field>
        <field name="arch" type="xml">
            <form string="Binary Manifest">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g., kopia"/></h1>
                    </div>
                    <group>
                        <field name="url"/>
                        <field name="checksum"/>
                        <field name="archive_type"/>
                        <field name="extract_member" invisible="archive_type != 'tar.gz'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_zero_sudo_binary_manifest" model="ir.actions.act_window">
        <field name="name">Binary Manifests</field>
        <field name="res_model">zero_sudo.binary.manifest</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_zero_sudo_binary_manifest"
              name="Binary Manifests"
              parent="base.menu_custom"
              action="action_zero_sudo_binary_manifest"
              sequence="150"/>
</odoo>
