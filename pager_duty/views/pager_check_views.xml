<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pager_check_list" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [%ANCHOR: test_pager_view] -->
        <field name="name">pager.check.list</field>
        <field name="model">pager.check</field>
        <field name="arch" type="xml">
            <list string="Monitoring Checks" decoration-danger="status == 'failing'" decoration-warning="status == 'maintenance'" decoration-success="status == 'passing'">
                <header>
                    <button name="action_pull_from_yaml" type="object" string="Pull from Daemon (YAML)" class="btn-secondary" confirm="This will overwrite your database checks with the current daemon YAML file. Continue?"/>
                    <button name="action_push_to_yaml" type="object" string="Push to Daemon (YAML)" class="btn-primary" confirm="This will write your current database checks to the daemon's YAML file and apply them. Continue?"/>
                </header>
                <field name="name"/>
                <field name="check_type"/>
                <field name="target"/>
                <field name="status"/>
                <field name="last_run"/>
            </list>
        </field>
    </record>

    <record id="view_pager_check_form" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [%ANCHOR: test_pager_view] -->
        <field name="name">pager.check.form</field>
        <field name="model">pager.check</field>
        <field name="arch" type="xml">
            <form string="Monitoring Check">
                <header>
                    <button name="action_trigger_check" type="object" string="Run Check Now" class="btn-primary"/>
                    <field name="status" widget="statusbar" statusbar_visible="passing,failing,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Core Router Ping"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="check_type"/>
                            <field name="target" invisible="check_type == 'heartbeat'"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="interval"/>
                            <field name="grace_period"/>
                            <field name="last_run" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Configuration">
                            <group>
                                <group>
                                    <field name="warning_threshold"/>
                                    <field name="critical_threshold"/>
                                    <field name="payload_expect" invisible="check_type not in ('http', 'http3', 'snmp')"/>
                                    <field name="parent_check_id"/>
                                    <field name="auto_remediate_script"/>
                                </group>
                                <group string="Protocol Specifics" invisible="check_type not in ('snmp', 'system')">
                                    <field name="snmp_community" invisible="check_type != 'snmp'"/>
                                    <field name="snmp_oid" invisible="check_type != 'snmp'"/>
                                    <field name="partition" invisible="check_type != 'system'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Maintenance">
                            <group>
                                <field name="maintenance_start"/>
                                <field name="maintenance_end"/>
                            </group>
                        </page>
                        <page string="Heartbeat Info" invisible="check_type != 'heartbeat'">
                            <group>
                                <field name="heartbeat_uuid"/>
                                <field name="last_heartbeat" readonly="1"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Send a POST request to <code>/api/v1/pager/heartbeat/&lt;uuid&gt;</code> to keep this check passing.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pager_check" model="ir.actions.act_window">
        <field name="name">Monitoring Configuration</field>
        <field name="res_model">pager.check</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pager_board" name="NOC Dashboard" parent="menu_admin_root" action="action_pager_board_client" sequence="10"/>
    <menuitem id="menu_pager_checks" name="Monitoring Checks" parent="menu_admin_root" action="action_pager_check" sequence="30"/>
</odoo>
