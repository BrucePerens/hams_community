<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="privilege_pager_duty">
            <field name="name">Pager Duty Management</field>
        </record>

        <record id="group_pager_admin" model="res.groups">
            <field name="name">Pager Duty Admin</field>
            <field name="privilege_id" ref="privilege_pager_duty"/>
        </record>

        <record id="group_pager_service" model="res.groups">
            <field name="name">Pager Duty Service Account Group</field>
            <field name="privilege_id" ref="privilege_pager_duty"/>
        </record>

        <record id="user_pager_service_internal" model="res.users">
            <field name="name">Pager Service Internal</field>
            <field name="login">pager_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('pager_duty.group_pager_service')])]"/>
        </record>
    </data>
</odoo>
