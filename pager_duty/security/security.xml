<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_pager_admin" model="res.groups">
            <field name="name">Pager Duty Admin</field>
        </record>
        <record id="user_pager_service_internal" model="res.users">
            <field name="name">Pager Service Internal</field>
            <field name="login">pager_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('pager_duty.group_pager_admin')])]"/>
        </record>
    
        <record id="group_mail_service" model="res.groups">
            <field name="name">Local Mail Service Account</field>
        </record>
        <record id="user_mail_service_internal" model="res.users">
            <field name="name">Pager Duty Mailer</field>
            <field name="login">pager_duty_mail_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('pager_duty.group_mail_service'), ref('base.group_user')])]"/>
        </record>
    </data>
</odoo>
