{
  "checks": [
    {
      "name": "Disk Space (/)",
      "type": "system",
      "target": "disk",
      "interval": 300,
      "critical": 90,
      "snmp_community": "public",
      "comment": "Autodiscovered disk space monitor for /",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Disk Space (/boot/efi)",
      "type": "system",
      "target": "disk",
      "interval": 300,
      "critical": 90,
      "snmp_community": "public",
      "partition": "/boot/efi",
      "comment": "Autodiscovered disk space monitor for /boot/efi",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Disk Space (/home)",
      "type": "system",
      "target": "disk",
      "interval": 300,
      "critical": 90,
      "snmp_community": "public",
      "partition": "/home",
      "comment": "Autodiscovered disk space monitor for /home",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Disk Space (/tmp)",
      "type": "system",
      "target": "disk",
      "interval": 300,
      "critical": 90,
      "snmp_community": "public",
      "partition": "/tmp",
      "comment": "Autodiscovered disk space monitor for /tmp",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Disk Space (/var)",
      "type": "system",
      "target": "disk",
      "interval": 300,
      "critical": 90,
      "snmp_community": "public",
      "partition": "/var",
      "comment": "Autodiscovered disk space monitor for /var",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Docker Daemon",
      "type": "systemd",
      "target": "docker.service",
      "interval": 60,
      "snmp_community": "public",
      "comment": "Autodiscovered Docker daemon monitor",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "IPv4 Root DNS Reachability",
      "type": "synthetic",
      "target": false,
      "interval": 300,
      "script": "dig -4 +time=3 +tries=1 @198.41.0.4 . NS",
      "snmp_community": "public",
      "comment": "Verifies IPv4 network routing to root DNS servers",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "IPv6 Root DNS Reachability",
      "type": "synthetic",
      "target": false,
      "interval": 300,
      "script": "dig -6 +time=3 +tries=1 @2001:503:ba3e::2:30 . NS",
      "snmp_community": "public",
      "comment": "Verifies IPv6 network routing to root DNS servers",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Nginx Config Readiness",
      "type": "nginx",
      "target": false,
      "interval": 3600,
      "snmp_community": "public",
      "comment": "Autodiscovered Nginx syntax check",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "PostgreSQL DB (Ping)",
      "type": "postgres",
      "target": "127.0.0.1",
      "interval": 60,
      "port": 5432,
      "dbname": "postgres",
      "user": "postgres",
      "snmp_community": "public",
      "comment": "Autodiscovered PostgreSQL instance",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "RabbitMQ AMQP",
      "type": "rabbitmq",
      "target": "ENV:RABBITMQ_HOST",
      "interval": 60,
      "port": 5672,
      "snmp_community": "public",
      "comment": "Autodiscovered RabbitMQ instance",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Redis Ping",
      "type": "redis",
      "target": "ENV:REDIS_HOST",
      "interval": 60,
      "port": 6379,
      "snmp_community": "public",
      "comment": "Autodiscovered Redis instance",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "System CPU",
      "type": "system",
      "target": "cpu",
      "interval": 60,
      "critical": 90,
      "snmp_community": "public",
      "comment": "Autodiscovered CPU monitor",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "Systemd Failed Services Tracker",
      "type": "systemd",
      "target": "*",
      "interval": 300,
      "snmp_community": "public",
      "ignored_services": "fwupd-refresh.service, NetworkManager-wait-online.service",
      "comment": "Autodiscovered global systemd failure tracker",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "System Load",
      "type": "load",
      "target": false,
      "interval": 60,
      "critical": 10,
      "snmp_community": "public",
      "comment": "Autodiscovered system load monitor",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "System Memory",
      "type": "system",
      "target": "memory",
      "interval": 60,
      "critical": 90,
      "snmp_community": "public",
      "comment": "Autodiscovered RAM monitor",
      "sandbox_network_access": "loopback"
    },
    {
      "name": "WSGI HTTP Ping",
      "type": "http",
      "target": "ENV:ODOO_URL",
      "interval": 60,
      "expect": "{\"status\": \"ok\"}",
      "snmp_community": "public",
      "grace": 120,
      "comment": "Autodiscovered local Odoo WSGI loopback ping",
      "sandbox_network_access": "loopback"
    }
  ],
  "log_analyzer": {
    "files": [],
    "patterns": []
  },
  "odoo_database": "hams_test"
}