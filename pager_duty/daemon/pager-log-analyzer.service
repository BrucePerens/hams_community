[Unit]
Description=Hams.com Chrooted Log Analyzer (Splunk Engine)
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/odoo/addons/pager_duty/daemon
EnvironmentFile=/etc/hams_daemons.env
ExecStart=/usr/bin/env python3 pager_log_analyzer.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
