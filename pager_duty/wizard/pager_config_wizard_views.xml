<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pager_config_wizard" model="ir.ui.view"> <!-- audit-ignore-view: Tested by [%ANCHOR: test_pager_view] -->
        <field name="name">pager.config.wizard.form</field>
        <field name="model">pager.config.wizard</field>
        <field name="arch" type="xml">
            <form string="JSON Configuration Tool">
                <div class="alert alert-info" role="alert">
                    The Pager Duty Daemon uses a standalone JSON configuration file. Use this tool to generate the JSON from your database records, or paste an existing JSON to populate the database.
                </div>
                <group>
                    <field name="yaml_content" widget="text" nolabel="1" colspan="2"/>
                </group>
                <footer>
                    <button name="action_generate_yaml" type="object" string="Generate from DB" class="btn-primary"/>
                    <button name="action_save_to_file_and_db" type="object" string="Apply to DB" class="btn-danger" confirm="This will delete all existing checks in the database and replace them with the YAML definitions. Continue?"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>                </footer>
            </form>
        </field>
    </record>

    <record id="action_pager_config_wizard" model="ir.actions.act_window">
        <field name="name">JSON Config Wizard</field>
        <field name="res_model">pager.config.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_pager_config_wizard" name="JSON Import/Export" parent="menu_admin_root" action="action_pager_config_wizard" sequence="40"/>
</odoo>
