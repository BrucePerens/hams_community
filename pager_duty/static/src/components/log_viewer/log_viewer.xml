<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pager_duty.LogViewerTemplate" owl="1">
        <div class="log-viewer p-4" style="background: #121212; min-height: 100vh; color: #33ff00; font-family: monospace;">
            <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded shadow-sm" style="background: #1e1e1e;">
                <h2 class="m-0 text-light"><i class="fa fa-terminal me-2"/>NOC Log Search</h2>
            </div>
            
            <div class="row mb-4">
                <div class="col-md-3">
                    <select class="form-select bg-dark text-light border-secondary" t-model="state.selectedFile">
                        <option value="">Select a Log File...</option>
                        <t t-foreach="state.files" t-as="file" t-key="file">
                            <option t-att-value="file"><t t-out="file"/></option>
                        </t>
                    </select>
                </div>
                <div class="col-md-7">
                    <input type="text" class="form-control bg-dark text-light border-secondary" placeholder="Enter RegEx (e.g. .*HTTP/1\.1&quot; 5\d\d)" t-model="state.regexQuery" t-on-keyup="onKeyup"/>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-success w-100" t-on-click="executeSearch" t-att-disabled="state.loading">
                        <i t-attf-class="fa {{ state.loading ? 'fa-spinner fa-spin' : 'fa-search' }} me-1"/> Search
                    </button>
                </div>
            </div>

            <div class="results-container p-3 rounded" style="background: #000; border: 1px solid #333; min-height: 60vh; max-height: 70vh; overflow-y: auto;">
                <t t-if="state.error">
                    <div class="text-danger"><i class="fa fa-warning me-1"/> <t t-out="state.error"/></div>
                </t>
                <t t-elif="state.results.length === 0 and !state.loading">
                    <div class="text-muted">No matches found or awaiting query...</div>
                </t>
                <t t-foreach="state.results" t-as="line" t-key="line_index">
                    <div style="border-bottom: 1px dashed #222; padding: 4px 0;"><t t-out="line"/></div>
                </t>
            </div>
        </div>
    </t>
</templates>
