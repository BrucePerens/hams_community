<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_backup_job_form" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_backup_view] -->
        <field name="name">backup.job.form</field>
        <field name="model">backup.job</field>
        <field name="arch" type="xml">
            <form string="Backup Job" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,processing,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="job_type" readonly="1"/> Backup Task</h1>
                    </div>
                    <group>
                        <group>
                            <field name="config_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Live Output Log">
                            <field name="output_log" widget="text" style="font-family: monospace; background-color: #000; color: #0f0; padding: 10px;" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_backup_job_list" model="ir.ui.view">
        <!-- audit-ignore-view: Tested by [@ANCHOR: test_backup_view] -->
        <field name="name">backup.job.list</field>
        <field name="model">backup.job</field>
        <field name="arch" type="xml">
            <list string="Backup Jobs" create="false" edit="false" decoration-info="state == 'processing'" decoration-success="state == 'done'" decoration-danger="state == 'failed'">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="job_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_backup_job" model="ir.actions.act_window">
        <field name="name">Backup Jobs (Active)</field>
        <field name="res_model">backup.job</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
