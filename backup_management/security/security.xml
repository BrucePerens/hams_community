<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_backup_admin" model="res.groups">
            <field name="name">Backup Administrator</field>
        </record>
        <record id="user_backup_service_internal" model="res.users">
            <field name="name">Backup Service Internal</field>
            <field name="login">backup_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('backup_management.group_backup_admin')])]"/>
        </record>
    
        <record id="group_mail_service" model="res.groups">
            <field name="name">Local Mail Service Account</field>
        </record>
        <record id="user_mail_service_internal" model="res.users">
            <field name="name">Backup Management Mailer</field>
            <field name="login">backup_management_mail_service_internal</field>
            <field name="is_service_account" eval="True"/>
            <field name="group_ids" eval="[(6, 0, [ref('backup_management.group_mail_service'), ref('base.group_user')])]"/>
        </record>
    </data>
</odoo>
