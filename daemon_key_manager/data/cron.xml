<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_rotate_daemon_keys" model="ir.cron">
            <!-- audit-ignore-cron: Tested by [@ANCHOR: test_cron_rotate_all_keys] -->
            <field name="name">Daemon Vault: Rotate API Keys</field>
            <field name="model_id" ref="daemon_key_manager.model_daemon_key_registry"/>
            <field name="user_id" ref="daemon_key_manager.user_daemon_key_manager_service"/>
            <field name="state">code</field>
            <field name="code">
# [@ANCHOR: cron_rotation_trigger]
model._cron_rotate_all_keys()
            </field>
            <field name="interval_number">60</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
